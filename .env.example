# Environment Variables for Tallman Dashboard
# Ensure this file is NOT committed to version control (e.g., add to .gitignore)

# --- P21 Connection (ODBC System DSN) ---
# Replace 'P21Play' with the exact name of your System DSN 
# configured in Windows ODBC Data Sources (x64)
P21_DSN=P21Live

# --- POR Connection (ODBC File Path) ---
# Replace with the correct *absolute* path to your POR database file
# Use double backslashes (\\) or forward slashes (/) for the path
POR_PATH=\\ts03\POR\POR.mdb

# If you need the path exposed client-side for debugging only, set:
NEXT_PUBLIC_POR_DB_PATH=\\ts03\POR\POR.mdb
# ⚠️  Avoid exposing production paths in the browser in real deployments.

# --- Application Port ---
PORT=3000

# -------------------------------------------------------------
# OPTIONAL SETTINGS
# -------------------------------------------------------------

# --- JSON Web Token (JWT) ---
JWT_SECRET="change_me_to_a_long_random_string_before_production"
JWT_EXPIRES_IN="1h" # e.g.  "15m", "8h", "7d"

# --- LDAP Configuration (only if LDAP_ENABLED=true) ---
LDAP_ENABLED="false"
LDAP_URL="ldap://your-ldap-server.com:389"
LDAP_BIND_DN="cn=admin,dc=example,dc=com"
LDAP_BIND_DN="cn=admin,dc=example,dc=com" # DN for a user with search permissions
LDAP_BIND_CREDENTIALS="your_ldap_bind_password"
LDAP_SEARCH_BASE="ou=users,dc=example,dc=com" # Base DN to search for users
LDAP_SEARCH_FILTER="(uid={{username}})" # Filter to find user. {{username}} is replaced by entered email/username.
# Example filters: (sAMAccountName={{username}}), (mail={{username}})
LDAP_SEARCH_ATTRIBUTES="uid,mail,displayName,cn,sn,givenName" # Comma-separated attributes to fetch from LDAP
LDAP_USER_LOGIN_ATTR="uid" # The LDAP attribute that uniquely identifies the user for login (e.g., uid, mail, sAMAccountName)
LDAP_TLS_REJECT_UNAUTHORIZED="true" # Set to "false" if using self-signed certs (not recommended for production)

# Application Port (already in your setup, but good to document)
PORT=3000

# NextAuth.js variables (if you were using NextAuth.js - keep for reference or remove if not planned)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=somereallysecretsecret