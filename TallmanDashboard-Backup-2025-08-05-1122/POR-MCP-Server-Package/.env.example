# POR MCP Server Configuration
# Copy this file to .env and configure with your settings

# POR Database File Path
# This should point to your POR MS Access database file (.mdb or .accdb)
POR_DB_PATH=C:\path\to\your\por\database.mdb

# Example configurations:
# POR_DB_PATH=C:\POR\Database\POR.mdb
# POR_DB_PATH=C:\POR\Database\POR.accdb
# POR_DB_PATH=\\server\share\POR\POR.mdb
# POR_DB_PATH=./data/POR.mdb

# Note: The database file must be accessible from this server
# Ensure proper file permissions and network connectivity if using network paths
