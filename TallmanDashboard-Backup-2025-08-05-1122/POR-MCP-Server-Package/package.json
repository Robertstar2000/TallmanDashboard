{
  "name": "por-server",
  "version": "0.1.0",
  "description": "MCP server for POR MS Access database connectivity",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "mdb-reader": "^3.1.0",
    "node-adodb": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "por-server": "build/index.js"
  }
}
