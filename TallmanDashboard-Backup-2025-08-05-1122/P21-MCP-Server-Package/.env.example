# P21 MCP Server Configuration
# Copy this file to .env and configure with your settings

# P21 Database ODBC DSN Name
# This should match the DSN name you created in ODBC Data Source Administrator
P21_DSN=P21_PROD

# Example configurations:
# P21_DSN=P21_TEST
# P21_DSN=P21_DEV
# P21_DSN=MyCompanyP21

# Note: The DSN must be configured in Windows ODBC Data Source Administrator
# with the correct server, database, and authentication settings
