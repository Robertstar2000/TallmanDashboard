{"metrics":[{"id":93,"rowId":"93","chartGroup":"Key Metrics","variableName":"Total_Orders","DataPoint":"Key Metrics - Order_count - Current Week","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(order_no) AS value FROM dbo.oe_hdr WHERE order_date >= DATEADD(WEEK, DATEDIFF(WEEK, 0, GETDATE()), 0) AND order_date < DATEADD(WEEK, DATEDIFF(WEEK, 0, GETDATE()) + 1, 0);","value":0,"lastUpdated":"2025-07-09 13:32:48","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Current Week"},{"id":94,"rowId":"94","chartGroup":"Key Metrics","variableName":"Open_Orders","DataPoint":"Key Metrics - Open Orders - All","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(order_no) AS value FROM dbo.oe_hdr WHERE order_date >= DATEADD(YEAR, -1, GETDATE());","value":0,"lastUpdated":"2025-07-09 13:32:50","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Current"},{"id":95,"rowId":"95","chartGroup":"Key Metrics","variableName":"Daily_Orders","DataPoint":"Key Metrics - Daily Orders - today","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(order_no) AS value FROM dbo.oe_hdr WHERE CAST(order_date AS DATE) = CAST(GETDATE() AS DATE);","value":0,"lastUpdated":"2025-07-09 13:32:52","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Today"},{"id":96,"rowId":"96","chartGroup":"Key Metrics","variableName":"Open_Invoices","DataPoint":"Key Metrics - Order_count - All","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(invoice_no) AS value FROM p21_view_GetOpenAR_dtl WHERE invoice_date >= DATEADD(YEAR, -1, GETDATE()) AND ArAmountOpen > 0;","value":0,"lastUpdated":"2025-07-09 13:32:54","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Current"},{"id":97,"rowId":"97","chartGroup":"Key Metrics","variableName":"Orders_Backloged","DataPoint":"Key Metrics - Orders Backloged - All","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(order_no) AS total_backlog_orders_last_12_months FROM dbo.oe_hdr WHERE order_date >= DATEADD(YEAR, -1, GETDATE()) AND date_order_completed IS NULL;","value":0,"lastUpdated":"2025-07-09 13:32:56","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Current"},{"id":98,"rowId":"98","chartGroup":"Key Metrics","variableName":"Order_count","DataPoint":"Key Metrics - Order_count - Current Day","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"SELECT COUNT(order_no) AS total_new_orders_today FROM dbo.oe_hdr WHERE CAST(order_date AS DATE) = CAST(GETDATE() AS DATE);","value":0,"lastUpdated":"2025-07-09 13:32:58","calculationType":"COUNT","chartName":"Key Metrics","axisStep":"Current Day"},{"id":99,"rowId":"99","chartGroup":"Key Metrics","variableName":"Total_Sales","DataPoint":"Key Metrics - Total Sales - Current Month","serverName":"P21","tableName":"dbo.OE_HDR","productionSqlExpression":"WITH invs AS ( SELECT invoice_no, MAX(invoice_date) AS invoice_date, MAX(total_sales) AS invoice_total FROM p21_sales_history_report_view WITH (NOLOCK) WHERE invoice_date >= DATEADD(MONTH,0,DATEFROMPARTS(YEAR(GETDATE()),MONTH(GETDATE()),1)) AND invoice_date < DATEADD(MONTH,1,DATEFROMPARTS(YEAR(GETDATE()),MONTH(GETDATE()),1)) GROUP BY invoice_no ) SELECT ISNULL(SUM(invoice_total),0) AS value FROM invs;","value":0,"lastUpdated":"2025-07-09 13:33:00","calculationType":"SUM","chartName":"Key Metrics","axisStep":"Last 12 Months"}],"accounts":[{"id":6,"rowId":"6","chartGroup":"Accounts","variableName":"Receivables","DataPoint":"Accounts - Receivables - Month -11","serverName":"P21","tableName":"dbo.p21_view_GetOpenAR_dtl","productionSqlExpression":"SELECT ISNULL(SUM(ArAmountOpen),0) AS value FROM dbo.p21_view_GetOpenAR_dtl WITH (NOLOCK) WHERE invoice_date >= DATEADD(MONTH,DATEDIFF(MONTH,0,GETDATE())-11,0) AND invoice_date < DATEADD(MONTH,DATEDIFF(MONTH,0,GETDATE())-10,0);","value":0,"lastUpdated":"2025-07-09 13:34:07","calculatio